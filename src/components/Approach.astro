---
const pillars = [
  {
    title: "Rigorous Diligence",
    description:
      "Every position is underwritten by sector specialists with independent credit and operational review before capital is committed.",
  },
  {
    title: "Aligned Incentives",
    description:
      "Our principals invest meaningful personal capital alongside every fund, ensuring outcomes are shared, not just promised.",
  },
  {
    title: "Disciplined Risk Management",
    description:
      "Concentration limits, structural protections, and active portfolio monitoring govern every strategy we deploy.",
  },
  {
    title: "Long-Term Partnership",
    description:
      "We build multi-decade relationships with our limited partners, grounded in transparency and consistent reporting.",
  },
];
---

<section id="approach" class="border-t border-line bg-ink">
  <div class="mx-auto max-w-7xl px-6 py-28 lg:px-10">
    <div class="grid gap-16 lg:grid-cols-[0.9fr_1.1fr] lg:gap-12">
      <div>
        <p class="eyebrow" data-reveal>Our Approach</p>
        <blockquote
          data-reveal
          class="mt-6 max-w-md text-balance font-display text-3xl font-light leading-snug text-cream sm:text-4xl"
        >
          We treat every dollar of limited partner capital as if it were our own
          <span class="text-gold">— because much of it is.</span>
        </blockquote>
      </div>

      <div data-reveal-group class="grid gap-x-10 gap-y-12 sm:grid-cols-2">
        {pillars.map((pillar, i) => (
          <div data-reveal-item class="border-t border-line pt-6">
            <span class="font-mono text-xs text-muted">0{i + 1}</span>
            <h3 class="mt-4 font-display text-xl font-medium text-cream">{pillar.title}</h3>
            <p class="mt-3 text-sm leading-relaxed text-cream-dim">{pillar.description}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>
