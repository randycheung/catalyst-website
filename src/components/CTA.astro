<section id="contact" class="relative flex min-h-screen items-center justify-center overflow-hidden border-b border-line bg-ink">
  <svg class="pointer-events-none absolute inset-0 h-full w-full opacity-[0.15]" viewBox="0 0 1200 800" fill="none" preserveAspectRatio="xMidYMid slice">
    <circle data-draw-path cx="600" cy="400" r="360" stroke="var(--color-gold)" stroke-width="1" />
    <circle data-draw-path cx="600" cy="400" r="260" stroke="var(--color-gold)" stroke-width="1" />
    <line data-draw-path x1="0" y1="400" x2="1200" y2="400" stroke="var(--color-gold)" stroke-width="1" />
  </svg>

  <div class="relative mx-auto max-w-4xl px-6 py-32 text-center lg:px-10">
    <p class="eyebrow justify-center" data-reveal>Partner With Catalyst</p>
    <h2
      data-reveal
      class="mt-7 text-balance font-display text-5xl font-light leading-[1.05] text-cream sm:text-6xl lg:text-7xl"
    >
      Built for Institutions. <span class="text-gold">Driven by Truth.</span>
    </h2>
    <p data-reveal class="mx-auto mt-7 max-w-lg text-balance text-base leading-relaxed text-cream-dim">
      For qualified institutional and professional investors, request access to our current strategies and most recent investor letter.
    </p>

    <div data-reveal class="mt-12 flex flex-wrap items-center justify-center gap-5">
      <a
        href="mailto:investors@randycheung.com"
        class="rounded-full bg-gold px-9 py-4 text-sm font-medium text-ink transition-transform duration-300 hover:scale-[1.03]"
      >
        Contact Us
      </a>
      <a
        href="mailto:investors@randycheung.com"
        class="rounded-full border border-line px-9 py-4 text-sm text-cream transition-colors duration-300 hover:border-gold hover:text-gold"
      >
        investors@randycheung.com
      </a>
    </div>
  </div>
</section>
