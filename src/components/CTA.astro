---

<section id="contact" class="relative overflow-hidden border-b border-line bg-ink">
  <div class="pointer-events-none absolute inset-0">
    <div
      class="absolute left-1/2 top-1/2 h-[600px] w-[900px] -translate-x-1/2 -translate-y-1/2 rounded-full opacity-25 blur-3xl"
      style="background: radial-gradient(circle, var(--color-emerald), transparent 70%);"
    >
    </div>
  </div>

  <div class="relative mx-auto max-w-4xl px-6 py-32 text-center lg:px-10">
    <p class="eyebrow justify-center" data-reveal>Partner With Catalyst</p>
    <h2
      data-reveal
      class="mt-7 text-balance font-display text-4xl font-light leading-tight text-cream sm:text-5xl lg:text-6xl"
    >
      Capital deserves a steady hand <span class="text-gold">and a long view.</span>
    </h2>
    <p data-reveal class="mx-auto mt-7 max-w-lg text-balance text-base leading-relaxed text-cream-dim">
      For qualified institutional and family office investors, request access to our current fund offerings and most recent investor letter.
    </p>

    <div data-reveal class="mt-12 flex flex-wrap items-center justify-center gap-5">
      <a
        href="mailto:investors@randycheung.com"
        class="rounded-full bg-gold px-8 py-3.5 text-sm font-medium text-ink transition-transform duration-300 hover:scale-[1.03]"
      >
        Request Investor Access
      </a>
      <a
        href="mailto:investors@randycheung.com"
        class="rounded-full border border-line px-8 py-3.5 text-sm text-cream transition-colors duration-300 hover:border-gold hover:text-gold"
      >
        investors@randycheung.com
      </a>
    </div>
  </div>
</section>
