---
const stats = [
  { value: "4.2", prefix: "$", suffix: "B", label: "Assets Under Management" },
  { value: "18", label: "Years of Track Record" },
  { value: "5", label: "Global Offices" },
  { value: "12", label: "Investment Strategies" },
];
---

<section class="relative flex min-h-screen items-center border-b border-line bg-ink">
  <svg
    class="pointer-events-none absolute -right-40 top-1/2 hidden h-[640px] w-[640px] -translate-y-1/2 opacity-20 lg:block"
    viewBox="0 0 600 600"
    fill="none"
  >
    <circle data-draw-path cx="300" cy="300" r="280" stroke="var(--color-gold)" stroke-width="1" />
    <circle data-draw-path cx="300" cy="300" r="200" stroke="var(--color-gold)" stroke-width="1" />
    <line data-draw-path x1="20" y1="300" x2="580" y2="300" stroke="var(--color-gold)" stroke-width="1" />
    <line data-draw-path x1="300" y1="20" x2="300" y2="580" stroke="var(--color-gold)" stroke-width="1" />
  </svg>

  <div class="relative mx-auto w-full max-w-7xl px-6 py-24 lg:px-10">
    <p class="eyebrow" data-reveal>By The Numbers</p>
    <h2 data-reveal class="mt-5 max-w-2xl text-balance font-display text-4xl font-light leading-tight text-cream sm:text-5xl">
      Scaled conviction, built over decades.
    </h2>

    <div data-reveal-group class="mt-20 grid grid-cols-2 gap-x-8 gap-y-16 lg:grid-cols-4">
      {stats.map((stat) => (
        <div data-reveal-item class="border-l border-gold/40 pl-6">
          <p class="font-display text-5xl font-light text-cream sm:text-6xl">
            {stat.prefix}<span data-counter={stat.value}>0</span>{stat.suffix}
          </p>
          <p class="mt-4 text-sm leading-snug text-muted">{stat.label}</p>
        </div>
      ))}
    </div>
  </div>
</section>
