---
const links = ["Strategies", "Philosophy", "Team", "Contact"];
---

<footer class="border-t border-line bg-ink">
  <div class="mx-auto max-w-7xl px-6 py-10 lg:px-10">
    <div class="flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
      <div class="flex items-baseline gap-2.5">
        <span class="font-display text-lg font-semibold tracking-tight text-cream">Catalyst</span>
        <span class="eyebrow">Funds Management</span>
      </div>

      <ul class="flex flex-wrap gap-6">
        {links.map((link) => (
          <li>
            <a
              href={`#${link.toLowerCase()}`}
              class="text-sm text-cream-dim transition-colors duration-300 hover:text-gold"
            >
              {link}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div class="mt-8 border-t border-line pt-6">
      <p class="text-xs leading-relaxed text-muted">
        For institutional and professional investors only. Not for retail distribution.
      </p>
      <p class="mt-3 text-xs text-muted">
        © 2026 Catalyst Funds Management. Sydney · Singapore · London · Dubai · New York.
      </p>
    </div>
  </div>
</footer>
