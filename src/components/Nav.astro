---
const links = [
  { href: "#strategies", label: "Strategies" },
  { href: "#approach", label: "Approach" },
  { href: "#performance", label: "Track Record" },
  { href: "#contact", label: "Contact" },
];
---

<header
  id="site-nav"
  class="fixed inset-x-0 top-0 z-50 border-b border-transparent transition-all duration-500"
>
  <nav class="mx-auto flex max-w-7xl items-center justify-between px-6 py-5 lg:px-10">
    <a href="#top" class="flex items-baseline gap-2.5">
      <span class="font-display text-xl font-semibold tracking-tight text-cream">Catalyst</span>
      <span class="eyebrow hidden sm:inline">Funds Management</span>
    </a>

    <ul class="hidden items-center gap-9 lg:flex">
      {links.map((link) => (
        <li>
          <a
            href={link.href}
            class="text-sm text-cream-dim transition-colors duration-300 hover:text-gold"
          >
            {link.label}
          </a>
        </li>
      ))}
    </ul>

    <a
      href="#contact"
      class="hidden rounded-full border border-gold/40 px-5 py-2 text-sm text-gold transition-colors duration-300 hover:border-gold hover:bg-gold/10 sm:inline-block"
    >
      Request Access
    </a>
  </nav>
</header>

<style>
  #site-nav.nav-solid {
    background-color: rgba(8, 8, 11, 0.85);
    backdrop-filter: blur(12px);
    border-bottom-color: var(--color-line);
  }
</style>
