---
---

<div data-gate class="fixed inset-0 z-[100] flex items-center justify-center bg-ink px-6">
  <svg
    class="pointer-events-none absolute inset-0 h-full w-full opacity-[0.08]"
    viewBox="0 0 1200 800"
    fill="none"
    preserveAspectRatio="xMidYMid slice"
  >
    <circle cx="600" cy="400" r="340" stroke="var(--color-gold)" stroke-width="1" />
    <circle cx="600" cy="400" r="240" stroke="var(--color-gold)" stroke-width="1" />
  </svg>

  <div class="relative w-full max-w-sm text-center">
    <span class="font-display text-3xl font-semibold tracking-tight text-cream">Catalyst</span>
    <p class="eyebrow mt-2">Funds Management</p>

    <p class="mt-8 text-sm leading-relaxed text-cream-dim">
      This site is restricted to authorized visitors. Enter the access password to continue.
    </p>

    <form data-gate-form class="mt-8" autocomplete="off">
      <label for="gate-password" class="sr-only">Site password</label>
      <input
        data-gate-input
        id="gate-password"
        name="site-password"
        type="password"
        required
        autocomplete="off"
        placeholder="Password"
        class="w-full rounded-full border border-gold/30 bg-surface px-5 py-3.5 text-center text-sm text-cream outline-none transition-colors duration-300 placeholder:text-muted focus:border-gold"
      />

      <p data-gate-error class="mt-3 hidden text-sm text-red-400">Access Denied</p>

      <button
        type="submit"
        class="mt-5 w-full rounded-full bg-gold px-7 py-3.5 text-sm font-medium text-ink transition-transform duration-300 hover:scale-[1.02]"
      >
        Enter
      </button>
    </form>

    <noscript>
      <p class="mt-6 text-xs text-muted">JavaScript is required to access this site.</p>
    </noscript>
  </div>
</div>
